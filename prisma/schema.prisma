// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  moduleFormat    = "cjs"
}


datasource db {
  provider = "postgresql"
}

model Organization {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  slug       String    @unique
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  users      User[]
  templates  Template[]

  @@map("organizations")
}


enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id             String    @id @default(uuid()) @db.Uuid
  email          String    @unique
  fullName       String    @map("full_name")
  role           UserRole  @default(MEMBER)
  
  assignedTasks  UserTask[]

  organizationId String       @db.Uuid @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  @@map("users")
}

model Template {
  id             String    @id @default(uuid()) @db.Uuid
  title          String
  description    String?
  
  tasks          Task[]

  organizationId String    @db.Uuid @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  @@map("templates")
}

model Task {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  content     String?
  order       Int      @default(0)
  
  templateId  String   @db.Uuid @map("template_id")
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  userTasks   UserTask[]

  @@map("tasks")
}

model UserTask {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid @map("user_id")
  taskId      String    @db.Uuid @map("task_id")
  
  completedAt DateTime? @map("completed_at") // Se null, não está concluída
  
  user        User      @relation(fields: [userId], references: [id])
  task        Task      @relation(fields: [taskId], references: [id])

  @@unique([userId, taskId])
  @@map("user_tasks")
}
